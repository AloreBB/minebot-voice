# MineBot dashboard
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here
ACCESS_PASSWORD=your-secret-password
JWT_SECRET=generate-a-random-string-here

# Encryption key for stored API keys — generate with: openssl rand -hex 32
ENCRYPTION_MASTER_KEY=generate-a-64-char-hex-string-here

# Minecraft server connection
MINECRAFT_HOST=minecraft
MINECRAFT_PORT=25565
BOT_USERNAME=MineBot

# Security: allowed CORS origins (comma-separated). Leave empty to block cross-origin.
# ALLOWED_ORIGINS=https://minebot.yourdomain.com

# Minecraft server (only for docker-compose.server.yml)
# Comma-separated, no spaces: Player1,Player2,MineBot
MC_WHITELIST=YourName,MineBot
MC_OPS=YourName,MineBot

# Data persistence
DB_PATH=./data/minebot.sqlite
MEMORY_DIR=./data/memories
